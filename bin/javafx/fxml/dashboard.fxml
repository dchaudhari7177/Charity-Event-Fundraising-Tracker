<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="javafx.controller.DashboardController"
            fitToWidth="true" style="-fx-background-color: #0D111B; -fx-control-inner-background: #0D111B;">

    <VBox spacing="32" style="-fx-padding: 32; -fx-background-color: #0D111B;">
        
        <!-- Header -->
        <VBox spacing="8">
            <Label text="Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E8EAED;" />
            <Label text="Welcome to Charity Tracker - Manage your events and donations with ease" 
                   style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;" />
        </VBox>

        <!-- Quick Stats -->
        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
            </columnConstraints>

            <!-- Total Events Card -->
            <VBox fx:id="statEventsCard" styleClass="stat-card" spacing="12" GridPane.columnIndex="0">
                <Label text="📅 TOTAL EVENTS" styleClass="stat-label" />
                <Label fx:id="totalEventsValue" text="0" styleClass="stat-value" />
                <Label fx:id="totalEventsChange" text="↑ 0% from last month" styleClass="stat-change,positive" />
            </VBox>

            <!-- Total Donors Card -->
            <VBox fx:id="statDonorsCard" styleClass="stat-card" spacing="12" GridPane.columnIndex="1">
                <Label text="👥 TOTAL DONORS" styleClass="stat-label" />
                <Label fx:id="totalDonorsValue" text="0" styleClass="stat-value" />
                <Label fx:id="totalDonorsChange" text="↑ 0% from last month" styleClass="stat-change,positive" />
            </VBox>

            <!-- Target Amount Card -->
            <VBox fx:id="statTargetCard" styleClass="stat-card" spacing="12" GridPane.columnIndex="2">
                <Label text="💰 TARGET AMOUNT" styleClass="stat-label" />
                <Label fx:id="targetAmountValue" text="₹0" styleClass="stat-value" />
                <Label fx:id="targetAmountChange" text="Total pledged" styleClass="stat-change,positive" />
            </VBox>

            <!-- Amount Collected Card -->
            <VBox fx:id="statCollectedCard" styleClass="stat-card" spacing="12" GridPane.columnIndex="3">
                <Label text="🎯 AMOUNT COLLECTED" styleClass="stat-label" />
                <Label fx:id="collectedAmountValue" text="₹0" styleClass="stat-value" />
                <Label fx:id="collectedAmountChange" text="0% achieved" styleClass="stat-change,positive" />
            </VBox>
        </GridPane>

        <!-- Quick Actions -->
        <VBox spacing="16">
            <Label text="Quick Actions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E8EAED;" />
            
            <GridPane hgap="16" vgap="16">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                </columnConstraints>

                <!-- Create Event Card -->
                <VBox fx:id="createEventCard" styleClass="action-card,cyan" spacing="12" GridPane.columnIndex="0" 
                      onMouseClicked="#handleCreateEvent" style="-fx-cursor: hand;">
                    <Label text="📅 Create Event" styleClass="action-title" />
                    <Label text="Start a new charity event and set targets" styleClass="action-subtitle" />
                </VBox>

                <!-- Register Donor Card -->
                <VBox fx:id="registerDonorCard" styleClass="action-card,green" spacing="12" GridPane.columnIndex="1"
                      onMouseClicked="#handleRegisterDonor" style="-fx-cursor: hand;">
                    <Label text="👤 Register Donor" styleClass="action-title" />
                    <Label text="Add a new donor to the system" styleClass="action-subtitle" />
                </VBox>

                <!-- Record Donation Card -->
                <VBox fx:id="recordDonationCard" styleClass="action-card,purple" spacing="12" GridPane.columnIndex="2"
                      onMouseClicked="#handleRecordDonation" style="-fx-cursor: hand;">
                    <Label text="💝 Record Donation" styleClass="action-title" />
                    <Label text="Record a new donation or pledge" styleClass="action-subtitle" />
                </VBox>
            </GridPane>
        </VBox>

        <!-- Recent Events -->
        <VBox spacing="12">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Recent Events" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E8EAED;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="View All" styleClass="btn,btn-primary" onAction="#handleViewAllEvents" />
            </HBox>

            <TableView fx:id="recentEventsTable" styleClass="table-view" minHeight="200" prefHeight="250">
                <columns>
                    <TableColumn text="Event Name" prefWidth="200" />
                    <TableColumn text="Target (₹)" prefWidth="120" />
                    <TableColumn text="Collected (₹)" prefWidth="120" />
                    <TableColumn text="Progress" prefWidth="120" />
                </columns>
            </TableView>
        </VBox>

    </VBox>

</ScrollPane>
