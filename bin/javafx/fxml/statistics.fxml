<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="javafx.controller.StatisticsController"
            fitToWidth="true" style="-fx-background-color: #0D111B; -fx-control-inner-background: #0D111B;">

    <VBox spacing="32" style="-fx-padding: 32; -fx-background-color: #0D111B;">
        
        <!-- Header -->
        <VBox spacing="8">
            <Label text="Statistics & Analytics" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E8EAED;" />
            <Label text="Overview of all charity activities and fundraising progress" 
                   style="-fx-font-size: 14px; -fx-text-fill: #9CA3AF;" />
        </VBox>

        <!-- Key Metrics -->
        <VBox spacing="12">
            <Label text="Key Metrics" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E8EAED;" />
            
            <GridPane hgap="16" vgap="16">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                </columnConstraints>

                <!-- Total Events Metric -->
                <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="0">
                    <Label text="📅 TOTAL EVENTS" styleClass="stat-label" />
                    <Label fx:id="metricsEvents" text="0" styleClass="stat-value" />
                    <Label text="Charity events created" styleClass="stat-change" style="-fx-text-fill: #9CA3AF;" />
                </VBox>

                <!-- Total Donors Metric -->
                <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="1">
                    <Label text="👥 TOTAL DONORS" styleClass="stat-label" />
                    <Label fx:id="metricsDonors" text="0" styleClass="stat-value" />
                    <Label text="Registered donors" styleClass="stat-change" style="-fx-text-fill: #9CA3AF;" />
                </VBox>

                <!-- Total Target Metric -->
                <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="2">
                    <Label text="🎯 TOTAL TARGET" styleClass="stat-label" />
                    <Label fx:id="metricsTarget" text="₹0" styleClass="stat-value" />
                    <Label text="Combined target amount" styleClass="stat-change" style="-fx-text-fill: #9CA3AF;" />
                </VBox>

                <!-- Total Collected Metric -->
                <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="3">
                    <Label text="💰 TOTAL COLLECTED" styleClass="stat-label" />
                    <Label fx:id="metricsCollected" text="₹0" styleClass="stat-value" />
                    <Label fx:id="metricsAchievement" text="0% achieved" styleClass="stat-change,positive" />
                </VBox>
            </GridPane>
        </VBox>

        <!-- Event Progress -->
        <VBox spacing="12">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Event Progress" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E8EAED;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="🔄 Refresh" styleClass="btn,btn-primary" onAction="#handleRefresh" />
            </HBox>

            <VBox styleClass="card" spacing="16" fx:id="eventProgressContainer">
                <!-- Event progress items added dynamically -->
                <Label text="Loading events..." style="-fx-text-fill: #9CA3AF;" />
            </VBox>
        </VBox>

    </VBox>

</ScrollPane>
